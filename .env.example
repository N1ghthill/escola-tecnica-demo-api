# PostgreSQL
DATABASE_URL=postgres://univitoria:univitoria@localhost:5432/univitoria
# Produção (serverless): prefira pooler (ex.: Supabase porta 6543)
# Ajustes opcionais do pool Node/pg:
# PG_POOL_MAX=3
# PG_IDLE_TIMEOUT_MS=5000
# PG_CONNECT_TIMEOUT_MS=10000
# PG_MAX_USES=7500

# URLs públicas
FRONTEND_BASE_URL=http://localhost:5500

# Modo demo (sem banco, sem pagamentos e sem integracoes externas)
# DEMO_MODE=true
# APP_MODE=demo

# CORS (opcional; lista separada por vírgula)
# FRONTEND_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
# Suporta wildcard no hostname (ex.: previews Vercel):
# FRONTEND_ALLOWED_ORIGINS=https://www.univitoriacursos.com.br,https://univitoria-tecnico-*.vercel.app

# e.Rede (checkout cartão)
# Modo oficial em produção: pre_matricula (checkout legado congelado).
# Para reativar checkout, exige:
#   ENROLLMENT_FLOW_MODE=checkout
#   ENABLE_ONLINE_PAYMENTS=true
ENROLLMENT_FLOW_MODE=pre_matricula
# REDE_ENV=sandbox
# Se seu banco forneceu apenas credencial real (sem sandbox), use:
# REDE_ENV=production
# REDE_PV=SEU_PV
# REDE_TOKEN=SUA_CHAVE_TOKEN
# REDE_SOFT_DESCRIPTOR=UNIVITORIA TEC
# REDE_TIMEOUT_MS=15000

# Token para consulta segura pelo matriculador (API interna)
# MATRICULADOR_TOKEN=troque-por-um-token-forte
# Alternativa mais segura: hash SHA-256 do token (hex de 64 chars)
# MATRICULADOR_TOKEN_SHA256=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Rotacao sem downtime (lista CSV de hashes)
# MATRICULADOR_TOKEN_SHA256_LIST=hash_antigo,hash_novo

# Alertas Telegram (opcional)
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# TELEGRAM_CHAT_ID=8718985388
# TELEGRAM_LEAD_ALERTS_ENABLED=true
# TELEGRAM_LEADS_BOT_TOKEN=123456:ABCDEF... # opcional (fallback TELEGRAM_BOT_TOKEN)
# TELEGRAM_LEADS_CHAT_ID=8718985388         # opcional (fallback TELEGRAM_CHAT_ID)
# TELEGRAM_ABANDONED_LEAD_ALERTS_ENABLED=true
# TELEGRAM_SALES_ALERTS_ENABLED=true
# TELEGRAM_SALES_BOT_TOKEN=123456:ABCDEF... # opcional (fallback TELEGRAM_BOT_TOKEN)
# TELEGRAM_SALES_CHAT_ID=8718985388         # opcional (fallback TELEGRAM_CHAT_ID)

# Meta Ads / Conversions API (opcional, recomendado para deduplicacao com Pixel)
# META_CONVERSIONS_ENABLED=true
# META_PIXEL_ID=1324681128200680
# META_CONVERSIONS_ACCESS_TOKEN=EAAB...
# META_TEST_EVENT_CODE=TEST12345
# META_GRAPH_API_VERSION=v22.0
# META_CONVERSIONS_TIMEOUT_MS=4500
